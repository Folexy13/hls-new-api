{
  "compilerOptions": {
    "target": "ES2020", // Updated from es2016
    "module": "commonjs",
    "moduleResolution": "node", // Explicitly set
    "rootDir": "./src", // Explicitly set
    "outDir": "./dist",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true, // Added for debugging
    "noEmitOnError": false // Allow build despite type errors (Express 5 compatibility issues)
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests"] // Expanded exclude
}
